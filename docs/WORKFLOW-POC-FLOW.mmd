flowchart TB
    A([Session Start]) --> B[Read required spec files]
    B --> C{Missing required file?}
    C -- Yes --> C1[Create/request missing file] --> B
    C -- No --> D{Prompt is vague?}

    D -- Yes --> D1[Ask up to 7 blocking questions]
    D1 --> D2{Blocking ambiguity resolved?}
    D2 -- No --> D1
    D2 -- Yes --> E[Proceed]
    D -- No --> E

    E --> F[Check mandatory clarification gates]
    F --> G{All gates resolved/defaulted?}
    G -- No --> G1[Log assumptions with confidence and verification path] --> F
    G -- Yes --> H{Session type}

    H -- Planning --> P[Research, identify edge cases, write planner.md and handoff.md, commit/push]
    H -- Execution --> X[Pull latest and implement handoff]
    P --> X

    X --> X1{API/compatibility uncertainty?}
    X1 -- Yes --> X2[Verify docs] --> X
    X1 -- No --> Y[Run verification/tests]

    Y --> Y1{Meets acceptance criteria?}
    Y1 -- No --> Y2[Fix issues or mark blocked] --> Y
    Y1 -- Yes --> Z[Write executor.md, update status files, append decisions/constraints, commit/push]

    Z --> N{More work needed?}
    N -- Yes --> N1[Create next session focus] --> A
    N -- No --> End([Session Loop Complete])

    classDef decision fill:#fff4cc,stroke:#946200,stroke-width:1px;
    classDef action fill:#e7f5ff,stroke:#1c7ed6,stroke-width:1px;

    class C,D,D2,G,H,X1,Y1,N decision;
    class A,B,C1,D1,E,F,G1,P,X,X2,Y,Y2,Z,N1,End action;
